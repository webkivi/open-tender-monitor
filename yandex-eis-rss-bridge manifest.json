{
  "manifest_version": 3,
  "name": "Open Tender Monitor: EIS RSS Bridge",
  "version": "0.1.0",
  "description": "Delivers official EIS RSS updates to a local Open Tender Monitor instance.",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://zakupki.gov.ru/*", "http://*/*"],
  "background": {"service_worker": "background.js", "type": "module"},
  "options_page": "options.html",
  "action": {"default_title": "EIS RSS Bridge"}
}
